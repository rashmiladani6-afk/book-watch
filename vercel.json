{
  "rewrites": [
    {
      "source": "/garba-auth/:path*",
      "destination": "https://www.garbatown.com/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://dwaaro.axenorsuite.com/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
